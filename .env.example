# ─── Kamerplanter Environment Configuration ───────────────────────
# Copy this file to .env and adjust values before starting:
#   cp .env.example .env
#
# IMPORTANT: Generate secure passwords before deploying!
#   Example:  openssl rand -base64 24

# ── Database (ArangoDB) ───────────────────────────────────────────
ARANGO_ROOT_PASSWORD=changeme
ARANGODB_DATABASE=kamerplanter
ARANGODB_USERNAME=root
ARANGODB_PASSWORD=changeme

# ── Cache / Queue (Valkey/Redis) ──────────────────────────────────
REDIS_URL=redis://valkey:6379/0

# ── Application ───────────────────────────────────────────────────
DEBUG=false
REQUIRE_EMAIL_VERIFICATION=false
CORS_ORIGINS=["http://localhost:8080"]
