# ─── Kamerplanter Environment Configuration ───────────────────────
# Copy this file to .env and adjust values before starting:
#   cp .env.example .env
#
# IMPORTANT: Generate secure passwords before deploying!
#   Example:  openssl rand -base64 24

# ── Database (ArangoDB) ───────────────────────────────────────────
ARANGO_ROOT_PASSWORD=changeme
ARANGODB_DATABASE=kamerplanter
ARANGODB_USERNAME=root
ARANGODB_PASSWORD=changeme

# ── Cache / Queue (Valkey/Redis) ──────────────────────────────────
REDIS_URL=redis://valkey:6379/0

# ── TimescaleDB (optional — for sensor time-series) ──────────────
# Enable with: docker-compose --profile timescaledb up
# TIMESCALEDB_ENABLED=false
# TIMESCALEDB_DATABASE=kamerplanter_sensors
# TIMESCALEDB_USERNAME=postgres
# TIMESCALEDB_PASSWORD=changeme

# ── VectorDB (optional — PostgreSQL + pgvector for AI/RAG) ───────
# Enable with: docker-compose --profile vectordb up
# VECTORDB_ENABLED=false
# VECTORDB_DATABASE=kamerplanter_vectors
# VECTORDB_USERNAME=postgres
# VECTORDB_PASSWORD=changeme
# EMBEDDING_SERVICE_URL=http://embedding-service:8080

# ── LLM (optional — for RAG knowledge assistant) ────────────────
# Enable Ollama with: docker-compose --profile ollama up
# Supported providers: anthropic, ollama, openai_compatible
# LLM_PROVIDER=ollama
# LLM_API_KEY=sk-ant-...           # Required for anthropic / openai_compatible
# LLM_API_URL=                      # Required for ollama (e.g. http://ollama:11434) / openai_compatible
# LLM_MODEL=claude-sonnet-4-20250514    # Model name for the chosen provider
# LLM_MAX_TOKENS=1024
# LLM_TEMPERATURE=0.3

# ── HuggingFace (optional — faster model downloads) ──────────────
# Free token from https://huggingface.co/settings/tokens (read access)
# HF_TOKEN=hf_...

# ── Application ───────────────────────────────────────────────────
DEBUG=false
REQUIRE_EMAIL_VERIFICATION=false
CORS_ORIGINS=["http://localhost:8080"]
