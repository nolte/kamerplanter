# Development Dockerfile for Kamerplanter frontend
# Runs Vite dev server with HMR
FROM node:22-alpine

LABEL org.opencontainers.image.description="Kamerplanter frontend UI (development with Vite HMR)"

WORKDIR /app

# Install dependencies first for better layer caching
COPY package.json package-lock.json ./
RUN npm ci

# Copy application code
COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
