FROM busybox:1.37.0

LABEL org.opencontainers.image.title="kamerplanter-ha-integration" \
      org.opencontainers.image.description="Kamerplanter Home Assistant custom integration" \
      org.opencontainers.image.source="https://github.com/nolte/kamerplanter" \
      org.opencontainers.image.vendor="Kamerplanter" \
      org.opencontainers.image.licenses="MIT"
COPY custom_components /ha-integration/custom_components
